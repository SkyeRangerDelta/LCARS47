# ===================================
# LCARS47 Environment Configuration
# ===================================
# Copy this file to .env and fill in your values
# See Src/Subsystems/Auxiliary/ENVChecks.json for detailed descriptions

# -----------------------------------
# CRITICAL - Bot cannot start without these
# -----------------------------------
TOKEN=your_discord_bot_token
RDS=mongodb://your_connection_string
PLDYNID=your_discord_guild_id
LCARSID=your_bot_user_id

# -----------------------------------
# REQUIRED - Core features need these
# -----------------------------------
OPENAIKEY=your_openai_api_key
MEDIALOG=channel_id_for_media_logging
ENGINEERING=channel_id_for_engineering_logs
SIMLAB=channel_id_for_simlab_gpt
DEVLAB=channel_id_for_devlab_gpt

# -----------------------------------
# OPTIONAL - API server (has defaults)
# -----------------------------------
# API_HOST=localhost
# API_PORT=9121

# -----------------------------------
# OPTIONAL - JWST integration
# -----------------------------------
# JWST=your_jwst_api_key

# -----------------------------------
# OPTIONAL - Beszel server monitoring
# All three required if using Beszel
# -----------------------------------
# BESZEL_URL=https://your-beszel-instance.com
# BESZEL_EMAIL=admin@example.com
# BESZEL_PASSWORD=your_beszel_password

# -----------------------------------
# OPTIONAL - Jellyfin media server
# All five required if using Jellyfin
# -----------------------------------
# JELLYFIN_HOST=localhost
# JELLYFIN_PORT=8096
# JELLYFIN_KEY=your_jellyfin_api_key
# JELLYFIN_USER=your_jellyfin_username
# JELLYFIN_PASS=your_jellyfin_password
