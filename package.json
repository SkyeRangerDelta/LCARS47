{
  "name": "lcars47",
  "version": "6.1.0-Experimental.1",
  "description": "Official PlDyn Development Discord Bot",
  "exports": "./lcars47.js",
  "scripts": {
    "dev": "tsc && node Deploy/lcars47.js --test",
    "ndev": "nodemon --watch './src/**/*.ts' --exec 'ts-node' src/lcars47.ts --test",
    "lint": "eslint .",
    "start": "node Deploy/lcars47.js",
    "build": "tsc",
    "build-run": "npm run build && npm run start",
    "test": "tsc && node Deploy/lcars47.js --heartbeat",
    "docker-build": "docker build -t lcars47 .",
    "docker-run": "docker run -d lcars47",
    "docker-stop": "docker stop $(docker ps -q --filter ancestor=lcars47)",
    "docker-build-run": "npm run docker-build && npm run docker-run",
    "release-dry": "semantic-release --dry-run"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SkyeRangerDelta/LCARS47"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/",
    "tag": "latest"
  },
  "author": "SkyeRangerDelta",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/SkyeRangerDelta/LCARS47/issues"
  },
  "homepage": "https://github.com/SkyeRangerDelta/LCARS47#readme",
  "dependencies": {
    "@discordjs/builders": "^1.11.3",
    "@discordjs/collection": "^2.0.0",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/rest": "^2.6.0",
    "@discordjs/voice": "^0.19.0",
    "@jellyfin/sdk": "^0.11.0",
    "@snazzah/davey": "^0.1.6",
    "colors": "^1.4.0",
    "discord-api-types": "^0.38.20",
    "discord.js": "^14.22.0",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "ffmpeg-static": "^5.1.0",
    "libsodium-wrappers": "^0.7.9",
    "mongodb": "^6.18.0",
    "openai": "^5.13.1",
    "opusscript": "^0.1.1",
    "pocketbase": "^0.26.3",
    "youtube-sr": "^4.3.12",
    "ytdlp-nodejs": "^2.3.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/express": "^5.0.3",
    "@types/luxon": "^3.7.1",
    "eslint": "^9.33.0",
    "jsdoc": "^4.0.2",
    "luxon": "^3.7.1",
    "semantic-release": "^24.2.7",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.40.0"
  },
  "engines": {
    "node": ">=18.20"
  }
}
