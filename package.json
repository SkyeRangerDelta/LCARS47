{
  "name": "lcars47",
  "version": "7.0.0-E.1",
  "description": "Official PlDyn Development Discord Bot",
  "exports": "./lcars47.js",
  "scripts": {
    "dev": "tsc && node Deploy/lcars47.js --test",
    "ndev": "nodemon --watch './src/*' dev",
    "lint": "eslint .",
    "start": "node Deploy/lcars47.js",
    "build": "tsc",
    "build-run": "npm run build && npm run start",
    "test": "vitest run 2>&1 | tee logs/tests/vitest-output.log",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage 2>&1 | tee logs/tests/vitest-output.log",
    "healthcheck": "tsc && node Deploy/lcars47.js --heartbeat",
    "docker-build": "node dockerBuild.js",
    "docker-run": "docker run -v ./.env:/LCARS47/.env -d -p 9121:9121 lcars47",
    "docker-stop": "docker stop $(docker ps -q --filter ancestor=lcars47)",
    "docker-build-run": "npm run docker-build && npm run docker-run",
    "release-dry": "semantic-release --dry-run",
    "coverage": "type-coverage --detail"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SkyeRangerDelta/LCARS47"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/",
    "tag": "latest"
  },
  "author": "SkyeRangerDelta",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/SkyeRangerDelta/LCARS47/issues"
  },
  "homepage": "https://github.com/SkyeRangerDelta/LCARS47#readme",
  "dependencies": {
    "@discordjs/builders": "^1.13.1",
    "@discordjs/collection": "^2.0.0",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.0",
    "@jellyfin/sdk": "^0.13.0",
    "@snazzah/davey": "^0.1.9",
    "colors": "^1.4.0",
    "discord-api-types": "^0.38.37",
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "libsodium-wrappers": "^0.8.2",
    "mongodb": "^7.0.0",
    "openai": "^6.17.0",
    "opusscript": "^0.1.1",
    "pocketbase": "^0.26.7",
    "youtube-sr": "^4.3.12",
    "ytdlp-nodejs": "^3.4.1",
    "luxon": "^3.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/luxon": "^3.7.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "jsdoc": "^4.0.5",
    "semantic-release": "^25.0.2",
    "type-coverage": "^2.29.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=24"
  }
}
